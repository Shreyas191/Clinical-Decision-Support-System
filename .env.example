# Copy this file to .env and fill in your keys
# Get GROQ_API_KEY free at: https://console.groq.com
# Get GOOGLE_API_KEY free at: https://aistudio.google.com
# Get GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET at: https://console.cloud.google.com
#   -> APIs & Services -> Credentials -> Create OAuth 2.0 Client ID (Web application)
#   -> Authorized redirect URIs: http://localhost:8000/auth/google/callback

GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
JWT_SECRET=replace_with_32_random_chars
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
ADMIN_EMAIL=your_admin_email@example.com
